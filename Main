public class Main {
    public static void main(String[] args) {

        AkunBank a1 = new AkunBank("Rameyza", "1234567890", "pass_word", 100000);
        AkunBank a2 = new AkunBank("Alya", "0987654321", "alya_pass", 50000);

        a1.tambahSaldo(20000, "pass_word");
        a2.tarikSaldo(10000, "salah");
        a2.tarikSaldo(10000, "alya_pass");

        a1.tampilkanInfo();
        a2.tampilkanInfo();
    }
}
